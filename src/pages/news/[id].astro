---
export function getStaticPaths() {
  return [
    { params: { id: '0' } },
    { params: { id: '1' } },
    { params: { id: '2' } },
  ];
}

const { id } = Astro.params;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cangjie UK Team — News</title>
  <link rel="icon" href="/assets/cangjie-icon.png" type="image/png">
  <meta name="theme-color" content="#20b2aa">
  <link rel="stylesheet" href="/css/index-style.css?v=20251030">
  <link rel="stylesheet" href="/css/blog-style.css?v=20260128">
  <script src="/js/site-nav.js" defer></script>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="brand brand-link">
        Cangjie UK
        <span class="brand-mark">
          <img class="brand-logo" src="/assets/cangjie-logo.png" alt="Cangjie Logo" loading="lazy">
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary">
      </nav>
    </div>
  </header>

  <main class="blog-main news-page-main">
    <div class="blog-main-inner news-page-inner">
      <a href="/" class="news-back-link">← Back to Home</a>
      <article class="news-article">
        <header class="news-article-header">
          <h1 class="news-article-title" id="news-title">News</h1>
          <time class="news-article-date" id="news-date" datetime="">—</time>
        </header>
        <div class="news-article-body md-window">
          <div id="news-content" data-news-id={id}>
            <div class="loading">Loading...</div>
          </div>
        </div>
      </article>
    </div>
  </main>

  <script define:vars={{ id }}>
    window.__INITIAL_NEWS_ID__ = parseInt(id, 10);
  </script>
  <script type="module" src="/js/news-script.js?v=20251030"></script>
</body>
</html>
